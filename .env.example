# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1
# Deployed app version: bump (e.g. to match git tag 1.0.1) so each release runs a one-time
# clear of localStorage + sessionStorage + React Query cache for returning users. Defaults to
# package.json `version` if unset (see next.config.js).
# NEXT_PUBLIC_APP_VERSION=1.0.1
